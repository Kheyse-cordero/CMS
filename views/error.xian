<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{statusCode}} Error - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
    <div class="max-w-md text-center px-4">
        <div class="mb-6">
            {{#if_eq statusCode 404}}
                <i class="fas fa-search text-7xl text-yellow-500"></i>
                <h1 class="text-5xl font-bold text-gray-800 mt-4">404</h1>
                <h2 class="text-2xl font-semibold text-gray-700 mt-2">Page Not Found</h2>
            {{else if_eq statusCode 403}}
                <i class="fas fa-lock text-7xl text-red-500"></i>
                <h1 class="text-5xl font-bold text-gray-800 mt-4">403</h1>
                <h2 class="text-2xl font-semibold text-gray-700 mt-2">Access Denied</h2>
            {{else if_eq statusCode 500}}
                <i class="fas fa-exclamation-triangle text-7xl text-red-600"></i>
                <h1 class="text-5xl font-bold text-gray-800 mt-4">500</h1>
                <h2 class="text-2xl font-semibold text-gray-700 mt-2">Server Error</h2>
            {{else}}
                <i class="fas fa-info-circle text-7xl text-blue-500"></i>
                <h1 class="text-5xl font-bold text-gray-800 mt-4">{{statusCode}}</h1>
                <h2 class="text-2xl font-semibold text-gray-700 mt-2">Error</h2>
            {{/if_eq}}
        </div>

        <p class="text-gray-600 text-lg mb-8">{{message}}</p>

        <div class="space-y-3">
            <a href="{{#if_eq statusCode 403}}/{{else}}/{{/if_eq}}" class="inline-block bg-blue-600 text-white font-bold px-6 py-3 rounded-lg hover:bg-blue-700 transition">
                <i class="fas fa-home"></i> Go to Home
            </a>
            <br>
            <a href="javascript:history.back()" class="inline-block bg-gray-300 text-gray-800 font-bold px-6 py-3 rounded-lg hover:bg-gray-400 transition">
                <i class="fas fa-arrow-left"></i> Go Back
            </a>
        </div>

        <div class="mt-8 p-4 bg-blue-50 rounded-lg border-l-4 border-blue-500">
            <p class="text-sm text-gray-600">
                <i class="fas fa-info-circle text-blue-600"></i>
                If you need help, contact us at <strong>info@minsu.edu.ph</strong>
            </p>
        </div>
    </div>
</body>
</html>
