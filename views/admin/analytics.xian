<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Analytics - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
        .animate-fade-in-down { animation: fadeInDown 0.6s ease-out; }
        .chart-card { transition: all 0.3s ease; }
        .chart-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-[#E8F5BD] to-gray-100 min-h-screen">
    {{>navbar}}
    <main class="md:ml-64 px-4 sm:px-6 lg:px-8 py-12">
        <!-- Page Title -->
        <div class="mb-10 animate-fade-in-down">
            <h1 class="text-3xl font-black text-gray-900 mb-2 flex items-center">
                <i class="fas fa-chart-line mr-3 text-[#84B179]"></i> System Analytics
            </h1>
            <p class="text-gray-600 text-sm">Monitor system performance and usage statistics</p>
        </div>

        <!-- User Statistics Section -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-8 animate-fade-in-up chart-card">
            <h2 class="text-xl font-black text-gray-900 mb-6 flex items-center">
                <i class="fas fa-users mr-3 text-[#84B179]"></i> User Statistics
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Users by Role Chart -->
                <div class="bg-gradient-to-br from-[#E8F5BD] to-[#C7EABB] p-6 rounded-xl border-2 border-[#C7EABB]">
                    <h3 class="text-base font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-pie-chart mr-2 text-[#84B179]"></i> Users by Role
                    </h3>
                    <canvas id="usersByRoleChart"></canvas>
                </div>

                <!-- Users by Status Chart -->
                <div class="bg-gradient-to-br from-[#E8F5BD] to-[#C7EABB] p-6 rounded-xl border-2 border-[#C7EABB]">
                    <h3 class="text-base font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-pie-chart mr-2 text-[#84B179]"></i> Users by Status
                    </h3>
                    <canvas id="usersByStatusChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Request Statistics Section -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-8 animate-fade-in-up chart-card" style="animation-delay: 0.1s">
            <h2 class="text-xl font-black text-gray-900 mb-6 flex items-center">
                <i class="fas fa-file-alt mr-3 text-[#84B179]"></i> Request Statistics
            </h2>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Requests by Status Chart -->
                <div class="bg-gradient-to-br from-[#E8F5BD] to-[#C7EABB] p-6 rounded-xl border-2 border-[#C7EABB]">
                    <h3 class="text-base font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-bar-chart mr-2 text-[#84B179]"></i> Requests by Status
                    </h3>
                    <canvas id="requestsByStatusChart"></canvas>
                </div>

                <!-- Requests by Type Chart -->
                <div class="bg-gradient-to-br from-[#E8F5BD] to-[#C7EABB] p-6 rounded-xl border-2 border-[#C7EABB]">
                    <h3 class="text-base font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-bar-chart mr-2 text-[#84B179]"></i> Requests by Document Type
                    </h3>
                    <canvas id="requestsByTypeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 animate-fade-in-up" style="animation-delay: 0.2s">
            <div class="bg-gradient-to-br from-[#84B179] to-[#84B179] rounded-xl shadow-lg p-6 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[#E8F5BD] text-xs font-bold mb-2">Total Users</p>
                        <p class="text-2xl font-black">{{userStats.byRole.length}}</p>
                    </div>
                    <div class="bg-[#A2CB8B] bg-opacity-30 rounded-full p-3">
                        <i class="fas fa-users text-3xl opacity-60"></i>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-[#84B179] to-[#6b9460] rounded-xl shadow-lg p-6 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[#E8F5BD] text-xs font-bold mb-2">Total Requests</p>
                        <p class="text-2xl font-black">{{requestsByStatus.length}}</p>
                    </div>
                    <div class="bg-[#84B179] bg-opacity-30 rounded-full p-3">
                        <i class="fas fa-file-alt text-3xl opacity-60"></i>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-[#6b9460] to-[#6b9460] rounded-xl shadow-lg p-6 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[#E8F5BD] text-xs font-bold mb-2">Document Types</p>
                        <p class="text-2xl font-black">{{requestsByType.length}}</p>
                    </div>
                    <div class="bg-[#84B179] bg-opacity-30 rounded-full p-3">
                        <i class="fas fa-copy text-3xl opacity-60"></i>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-[#6b9460] to-[#5a7a51] rounded-xl shadow-lg p-6 text-white">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[#E8F5BD] text-xs font-bold mb-2">System Health</p>
                        <p class="text-2xl font-black">Excellent</p>
                    </div>
                    <div class="bg-[#6b9460] bg-opacity-30 rounded-full p-3">
                        <i class="fas fa-heartbeat text-3xl opacity-60"></i>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Chart.js configuration
        const chartOptions = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        font: { size: 12, weight: 'bold' },
                        padding: 15,
                        usePointStyle: true
                    }
                }
            }
        };

        // Users by Role Chart
        const usersByRoleCtx = document.getElementById('usersByRoleChart').getContext('2d');
        new Chart(usersByRoleCtx, {
            type: 'doughnut',
            data: {
                labels: ['Students', 'Registrar', 'Admins'],
                datasets: [{
                    data: [65, 25, 10],
                    backgroundColor: [
                        'rgba(132, 177, 121, 0.8)',
                        'rgba(168, 85, 247, 0.8)',
                        'rgba(239, 68, 68, 0.8)'
                    ],
                    borderColor: [
                        'rgb(132, 177, 121)',
                        'rgb(168, 85, 247)',
                        'rgb(239, 68, 68)'
                    ],
                    borderWidth: 2
                }]
            },
            options: chartOptions
        });

        // Users by Status Chart
        const usersByStatusCtx = document.getElementById('usersByStatusChart').getContext('2d');
        new Chart(usersByStatusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Inactive', 'Suspended'],
                datasets: [{
                    data: [80, 15, 5],
                    backgroundColor: [
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(156, 163, 175, 0.8)',
                        'rgba(239, 68, 68, 0.8)'
                    ],
                    borderColor: [
                        'rgb(34, 197, 94)',
                        'rgb(156, 163, 175)',
                        'rgb(239, 68, 68)'
                    ],
                    borderWidth: 2
                }]
            },
            options: chartOptions
        });

        // Requests by Status Chart
        const requestsByStatusCtx = document.getElementById('requestsByStatusChart').getContext('2d');
        new Chart(requestsByStatusCtx, {
            type: 'bar',
            data: {
                labels: ['Pending', 'Processing', 'Ready', 'Completed', 'Rejected'],
                datasets: [{
                    label: 'Number of Requests',
                    data: [12, 19, 8, 45, 3],
                    backgroundColor: [
                        'rgba(234, 179, 8, 0.8)',
                        'rgba(132, 177, 121, 0.8)',
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(5, 150, 105, 0.8)',
                        'rgba(239, 68, 68, 0.8)'
                    ],
                    borderColor: [
                        'rgb(234, 179, 8)',
                        'rgb(132, 177, 121)',
                        'rgb(34, 197, 94)',
                        'rgb(5, 150, 105)',
                        'rgb(239, 68, 68)'
                    ],
                    borderWidth: 2,
                    borderRadius: 5
                }]
            },
            options: {
                ...chartOptions,
                indexAxis: 'y',
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true
                    }
                }
            }
        });

        // Requests by Type Chart
        const requestsByTypeCtx = document.getElementById('requestsByTypeChart').getContext('2d');
        new Chart(requestsByTypeCtx, {
            type: 'bar',
            data: {
                labels: ['Transcript', 'Diploma', 'Certificate', 'Verification', 'Enrollment', 'Good Moral'],
                datasets: [{
                    label: 'Number of Requests',
                    data: [25, 15, 12, 18, 20, 10],
                    backgroundColor: [
                        'rgba(168, 85, 247, 0.8)',
                        'rgba(236, 72, 153, 0.8)',
                        'rgba(132, 177, 121, 0.8)',
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(234, 179, 8, 0.8)',
                        'rgba(249, 115, 22, 0.8)'
                    ],
                    borderColor: [
                        'rgb(168, 85, 247)',
                        'rgb(236, 72, 153)',
                        'rgb(132, 177, 121)',
                        'rgb(34, 197, 94)',
                        'rgb(234, 179, 8)',
                        'rgb(249, 115, 22)'
                    ],
                    borderWidth: 2,
                    borderRadius: 5
                }]
            },
            options: {
                ...chartOptions,
                indexAxis: 'y',
                plugins: {
                    legend: {
                        display: true
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>

    {{>footer}}
</body>
</html>
