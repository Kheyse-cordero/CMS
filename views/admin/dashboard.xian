<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; opacity: 0; }
        .animate-fade-in-down { animation: fadeInDown 0.6s ease-out; }
        .stat-card { transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .stat-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1); }
        .action-btn { transition: all 0.3s ease; }
        .action-btn:hover { transform: scale(1.05); box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15); }
        .table-row-hover { transition: all 0.2s ease; }
        .table-row-hover:hover { background-color: #f3f4f6; transform: translateX(4px); }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-red-50 to-gray-100 min-h-screen">
    {{>navbar}}

    <main class="max-w-7xl mx-auto px-6 py-12 pt-24">
        <!-- Page Title -->
        <div class="animate-fade-in-down mb-10">
            <h1 class="text-5xl font-black text-gray-800 mb-2">System Administration</h1>
            <p class="text-gray-600 text-lg">Monitor, manage users and system settings</p>
        </div>

        <!-- Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            <div class="stat-card bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl shadow-lg p-8 border-l-4 border-blue-600 animate-fade-in-up" style="animation-delay: 0.1s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-blue-700 text-sm font-bold mb-3 uppercase tracking-wide">Total Users</p>
                        <p class="text-4xl font-black text-blue-600">{{stats.totalUsers}}</p>
                    </div>
                    <div class="bg-blue-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-users text-4xl text-blue-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-green-50 to-emerald-100 rounded-xl shadow-lg p-8 border-l-4 border-green-600 animate-fade-in-up" style="animation-delay: 0.15s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-green-700 text-sm font-bold mb-3 uppercase tracking-wide">Students</p>
                        <p class="text-4xl font-black text-green-600">{{stats.totalStudents}}</p>
                    </div>
                    <div class="bg-green-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-graduation-cap text-4xl text-green-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl shadow-lg p-8 border-l-4 border-purple-600 animate-fade-in-up" style="animation-delay: 0.2s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-purple-700 text-sm font-bold mb-3 uppercase tracking-wide">Registrar Staff</p>
                        <p class="text-4xl font-black text-purple-600">{{stats.totalRegistrars}}</p>
                    </div>
                    <div class="bg-purple-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-briefcase text-4xl text-purple-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-red-50 to-red-100 rounded-xl shadow-lg p-8 border-l-4 border-red-600 animate-fade-in-up" style="animation-delay: 0.22s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-red-700 text-sm font-bold mb-3 uppercase tracking-wide">Admin Users</p>
                        <p class="text-4xl font-black text-red-600">{{stats.totalAdmins}}</p>
                    </div>
                    <div class="bg-red-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-crown text-4xl text-red-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-emerald-50 to-teal-100 rounded-xl shadow-lg p-8 border-l-4 border-emerald-600 animate-fade-in-up" style="animation-delay: 0.25s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-emerald-700 text-sm font-bold mb-3 uppercase tracking-wide">Active Users</p>
                        <p class="text-4xl font-black text-emerald-600">{{stats.activeUsers}}</p>
                    </div>
                    <div class="bg-emerald-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-check-circle text-4xl text-emerald-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-yellow-50 to-amber-100 rounded-xl shadow-lg p-8 border-l-4 border-yellow-600 animate-fade-in-up" style="animation-delay: 0.3s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-yellow-700 text-sm font-bold mb-3 uppercase tracking-wide">Total Requests</p>
                        <p class="text-4xl font-black text-yellow-600">{{stats.totalRequests}}</p>
                    </div>
                    <div class="bg-yellow-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-file-alt text-4xl text-yellow-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-orange-50 to-orange-100 rounded-xl shadow-lg p-8 border-l-4 border-orange-600 animate-fade-in-up" style="animation-delay: 0.32s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-orange-700 text-sm font-bold mb-3 uppercase tracking-wide">Pending Requests</p>
                        <p class="text-4xl font-black text-orange-600">{{stats.pendingRequests}}</p>
                    </div>
                    <div class="bg-orange-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-hourglass-start text-4xl text-orange-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-cyan-50 to-cyan-100 rounded-xl shadow-lg p-8 border-l-4 border-cyan-600 animate-fade-in-up" style="animation-delay: 0.34s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-cyan-700 text-sm font-bold mb-3 uppercase tracking-wide">Processing</p>
                        <p class="text-4xl font-black text-cyan-600">{{stats.processingRequests}}</p>
                    </div>
                    <div class="bg-cyan-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-spinner text-4xl text-cyan-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl shadow-lg p-8 border-l-4 border-indigo-600 animate-fade-in-up" style="animation-delay: 0.36s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-indigo-700 text-sm font-bold mb-3 uppercase tracking-wide">Appointments</p>
                        <p class="text-4xl font-black text-indigo-600">{{stats.totalAppointments}}</p>
                    </div>
                    <div class="bg-indigo-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-calendar text-4xl text-indigo-600 opacity-70"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="action-btn bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.4s">
                <div class="mb-6"><i class="fas fa-users text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Manage Users</h3>
                <p class="mb-8 text-blue-100 text-lg">Add, edit, delete users</p>
                <a href="/admin/users" class="inline-block bg-white text-blue-600 px-8 py-3 rounded-xl font-bold hover:bg-blue-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
            <div class="action-btn bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.45s">
                <div class="mb-6"><i class="fas fa-chart-pie text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Analytics</h3>
                <p class="mb-8 text-purple-100 text-lg">View system analytics</p>
                <a href="/admin/analytics" class="inline-block bg-white text-purple-600 px-8 py-3 rounded-xl font-bold hover:bg-purple-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
            <div class="action-btn bg-gradient-to-br from-orange-600 to-orange-800 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.5s">
                <div class="mb-6"><i class="fas fa-chart-bar text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Reports</h3>
                <p class="mb-8 text-orange-100 text-lg">Generate reports</p>
                <a href="/registrar/report" class="inline-block bg-white text-orange-600 px-8 py-3 rounded-xl font-bold hover:bg-orange-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
        </div>

        <!-- Recent Users -->
        <!-- Recent Users -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden animate-fade-in-up" style="animation-delay: 0.55s">
            <div class="bg-gradient-to-r from-gray-800 to-gray-900 px-8 py-6">
                <h2 class="text-white text-2xl font-black flex items-center"><i class="fas fa-history mr-3"></i> Recent Users</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-100 border-b-2 border-gray-300">
                        <tr>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Name</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Email</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Role</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Status</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Date</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each recentUsers}}
                            <tr class="table-row-hover border-b-2 border-gray-200">
                                <td class="px-8 py-5 text-gray-800 font-medium"><i class="fas fa-user mr-2 text-blue-600"></i>{{this.name}}</td>
                                <td class="px-8 py-5 text-gray-600">{{this.email}}</td>
                                <td class="px-8 py-5">
                                    <span class="px-4 py-2 rounded-full text-sm font-bold bg-blue-100 text-blue-800 inline-flex items-center"><i class="fas fa-tag mr-2"></i>{{this.role}}</span>
                                </td>
                                <td class="px-8 py-5">
                                    {{#switch this.status}}
                                        {{#case 'active'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-green-100 text-green-800 inline-flex items-center"><i class="fas fa-check-circle mr-2"></i>Active</span>{{/case}}
                                        {{#case 'inactive'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-gray-100 text-gray-800 inline-flex items-center"><i class="fas fa-minus-circle mr-2"></i>Inactive</span>{{/case}}
                                        {{#case 'suspended'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-red-100 text-red-800 inline-flex items-center"><i class="fas fa-ban mr-2"></i>Suspended</span>{{/case}}
                                    {{/switch}}
                                </td>
                                <td class="px-8 py-5 text-gray-600 font-medium">{{formatDate this.createdAt}}</td>
                                <td class="px-8 py-5"><a href="/admin/users/{{this.id}}" class="text-blue-600 hover:text-blue-800 font-bold inline-flex items-center transition hover:translate-x-1"><i class="fas fa-arrow-right mr-2"></i>View</a></td>
                            </tr>
                        {{else}}
                            <tr>
                                <td colspan="6" class="px-8 py-8 text-center text-gray-500"><i class="fas fa-inbox text-3xl mb-2 block opacity-50"></i>No users found</td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Requests -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden animate-fade-in-up mt-12" style="animation-delay: 0.6s">
            <div class="bg-gradient-to-r from-gray-800 to-gray-900 px-8 py-6">
                <h2 class="text-white text-2xl font-black flex items-center"><i class="fas fa-file-alt mr-3"></i> Recent Document Requests</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-100 border-b-2 border-gray-300">
                        <tr>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Student Name</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Document Type</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Status</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Date Requested</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if recentRequests.length}}
                            {{#each recentRequests}}
                            <tr class="table-row-hover border-b-2 border-gray-200">
                                <td class="px-8 py-5 text-gray-800 font-medium"><i class="fas fa-user mr-2 text-blue-600"></i>{{this.student.name}}</td>
                                <td class="px-8 py-5 text-gray-600">{{this.documentType}}</td>
                                <td class="px-8 py-5">
                                    {{#switch this.status}}
                                        {{#case 'pending'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 inline-flex items-center"><i class="fas fa-hourglass-start mr-2"></i>Pending</span>{{/case}}
                                        {{#case 'processing'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-blue-100 text-blue-800 inline-flex items-center"><i class="fas fa-spinner mr-2"></i>Processing</span>{{/case}}
                                        {{#case 'ready'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-green-100 text-green-800 inline-flex items-center"><i class="fas fa-check-circle mr-2"></i>Ready</span>{{/case}}
                                        {{#case 'completed'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-emerald-100 text-emerald-800 inline-flex items-center"><i class="fas fa-check-double mr-2"></i>Completed</span>{{/case}}
                                        {{#case 'rejected'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-red-100 text-red-800 inline-flex items-center"><i class="fas fa-times-circle mr-2"></i>Rejected</span>{{/case}}
                                    {{/switch}}
                                </td>
                                <td class="px-8 py-5 text-gray-600 font-medium">{{formatDate this.createdAt}}</td>
                                <td class="px-8 py-5"><a href="/registrar/requests/{{this.id}}" class="text-blue-600 hover:text-blue-800 font-bold inline-flex items-center transition hover:translate-x-1"><i class="fas fa-arrow-right mr-2"></i>View</a></td>
                            </tr>
                            {{/each}}
                        {{else}}
                        <tr>
                            <td colspan="5" class="px-8 py-8 text-center text-gray-500"><i class="fas fa-inbox text-3xl mb-2 block opacity-50"></i>No requests found</td>
                        </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    {{>footer}}
</body>
</html>
