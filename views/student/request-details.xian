<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-up {
            animation: fadeInUp 0.6s ease-out;
        }
        .animate-fade-in-down {
            animation: fadeInDown 0.6s ease-out;
        }
        .animate-slide-in-up {
            animation: slideInUp 0.8s ease-out;
        }
        .stat-card {
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(59, 130, 246, 0.2);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 min-h-screen pt-20">
    {{>navbar}}
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Page Title -->
        <div class="mb-8 animate-fade-in-down">
            <h1 class="text-5xl font-black text-gray-900 flex items-center mb-2">
                <i class="fas fa-file-alt mr-4 text-blue-600"></i> Request Details
            </h1>
            <p class="text-gray-600 text-lg">View and manage your document request</p>
        </div>

        <!-- Back Button -->
        <div class="mb-6">
            <a href="/student/requests" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-bold transition">
                <i class="fas fa-arrow-left mr-2"></i> Back to My Requests
            </a>
        </div>

        <!-- Request Details Card -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden animate-slide-in-up">
            <!-- Header -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-8">
                <div class="flex justify-between items-start">
                    <div>
                        <h2 class="text-white text-3xl font-black flex items-center mb-2">
                            <i class="fas fa-{{#switch request.documentType}}{{#case 'transcript'}}graduation-cap{{/case}}{{#case 'diploma'}}certificate{{/case}}{{#case 'certificate'}}award{{/case}}{{#case 'verification'}}check-circle{{/case}}{{#case 'enrollment_certificate'}}id-card{{/case}}{{#case 'good_moral'}}star{{/case}}{{/switch}} mr-3"></i>
                            {{request.documentType}}
                        </h2>
                        <p class="text-blue-100">Request ID: {{request.id}}</p>
                    </div>
                    <!-- Status Badge -->
                    <div>
                        {{#switch request.status}}
                            {{#case 'pending'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-yellow-100 text-yellow-800 inline-flex items-center">
                                    <i class="fas fa-hourglass-start mr-2"></i> Pending
                                </span>
                            {{/case}}
                            {{#case 'processing'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-blue-100 text-blue-800 inline-flex items-center">
                                    <i class="fas fa-spinner mr-2"></i> Processing
                                </span>
                            {{/case}}
                            {{#case 'ready'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-green-100 text-green-800 inline-flex items-center">
                                    <i class="fas fa-check-circle mr-2"></i> Ready
                                </span>
                            {{/case}}
                            {{#case 'completed'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-emerald-100 text-emerald-800 inline-flex items-center">
                                    <i class="fas fa-check-double mr-2"></i> Completed
                                </span>
                            {{/case}}
                            {{#case 'rejected'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-red-100 text-red-800 inline-flex items-center">
                                    <i class="fas fa-times-circle mr-2"></i> Rejected
                                </span>
                            {{/case}}
                        {{/switch}}
                    </div>
                </div>
            </div>

            <!-- Details Content -->
            <div class="px-8 py-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                    <!-- Left Column -->
                    <div class="space-y-6">
                        <div class="stat-card bg-gradient-to-br from-blue-50 to-indigo-50 p-6 rounded-xl border-l-4 border-blue-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-calendar mr-2 text-blue-600"></i> DATE REQUESTED
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{formatDate request.createdAt}}</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-purple-50 to-pink-50 p-6 rounded-xl border-l-4 border-purple-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-copy mr-2 text-purple-600"></i> QUANTITY
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{request.quantity}} {{#if_eq request.quantity 1}}Copy{{else}}Copies{{/if_eq}}</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-green-50 to-emerald-50 p-6 rounded-xl border-l-4 border-green-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-info-circle mr-2 text-green-600"></i> PURPOSE
                            </p>
                            <p class="text-gray-900 font-semibold">{{request.purpose}}</p>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="space-y-6">
                        {{#if request.registrar}}
                        <div class="stat-card bg-gradient-to-br from-orange-50 to-red-50 p-6 rounded-xl border-l-4 border-orange-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-user-tie mr-2 text-orange-600"></i> PROCESSED BY
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{request.registrar.name}}</p>
                        </div>
                        {{/if}}

                        {{#if request.completedAt}}
                        <div class="stat-card bg-gradient-to-br from-emerald-50 to-teal-50 p-6 rounded-xl border-l-4 border-emerald-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-flag-checkered mr-2 text-emerald-600"></i> COMPLETED DATE
                            </p>
                            <p class="text-lg font-bold text-gray-900">{{formatDate request.completedAt}}</p>
                        </div>
                        {{/if}}

                        {{#if request.notes}}
                        <div class="stat-card bg-gradient-to-br from-indigo-50 to-blue-50 p-6 rounded-xl border-l-4 border-indigo-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-sticky-note mr-2 text-indigo-600"></i> NOTES
                            </p>
                            <p class="text-gray-900">{{request.notes}}</p>
                        </div>
                        {{/if}}

                        {{#if request.rejectionReason}}
                        <div class="stat-card bg-gradient-to-br from-red-50 to-pink-50 p-6 rounded-xl border-l-4 border-red-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-exclamation-triangle mr-2 text-red-600"></i> REJECTION REASON
                            </p>
                            <p class="text-gray-900">{{request.rejectionReason}}</p>
                        </div>
                        {{/if}}
                    </div>
                </div>

                <!-- Appointments Section -->
                {{#if appointments}}
                <div class="mt-12 pt-8 border-t-2 border-gray-200">
                    <h3 class="text-2xl font-black text-gray-900 mb-6 flex items-center">
                        <i class="fas fa-calendar-check mr-3 text-blue-600"></i> Scheduled Appointments
                    </h3>
                    
                    {{#if appointments.length}}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {{#each appointments}}
                        <div class="bg-gradient-to-br from-purple-50 to-blue-50 p-6 rounded-xl border-2 border-purple-200 stat-card" style="animation-delay: {{multiply @index 0.1}}s">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <p class="text-gray-600 text-sm font-bold">
                                        <i class="fas fa-clock mr-2"></i> {{formatDate this.appointmentDate}} at {{this.appointmentTime}}
                                    </p>
                                </div>
                                <span class="px-3 py-1 rounded-full text-sm font-bold bg-purple-100 text-purple-800 inline-flex items-center">
                                    {{#switch this.status}}
                                        {{#case 'scheduled'}}<i class="fas fa-calendar mr-1"></i> Scheduled{{/case}}
                                        {{#case 'completed'}}<i class="fas fa-check mr-1"></i> Completed{{/case}}
                                        {{#case 'missed'}}<i class="fas fa-times mr-1"></i> Missed{{/case}}
                                        {{#case 'cancelled'}}<i class="fas fa-ban mr-1"></i> Cancelled{{/case}}
                                        {{#case 'rescheduled'}}<i class="fas fa-sync mr-1"></i> Rescheduled{{/case}}
                                    {{/switch}}
                                </span>
                            </div>
                            {{#if this.notes}}
                            <p class="text-gray-700 text-sm mb-2">
                                <strong>Notes:</strong> {{this.notes}}
                            </p>
                            {{/if}}
                            {{#if this.registrarNotes}}
                            <p class="text-gray-700 text-sm">
                                <strong>Registrar Notes:</strong> {{this.registrarNotes}}
                            </p>
                            {{/if}}
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <p class="text-center text-gray-600 py-8">
                        <i class="fas fa-inbox text-4xl mb-4 text-gray-400"></i>
                        <p>No appointments scheduled yet</p>
                    </p>
                    {{/if}}
                </div>
                {{/if}}

                <!-- Action Buttons -->
                <div class="mt-12 pt-8 border-t-2 border-gray-200 flex gap-4">
                    {{#if_eq request.status 'pending'}}
                    <form method="POST" action="/student/requests/{{request.id}}/cancel" style="display: inline;">
                        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105 shadow-lg">
                            <i class="fas fa-times mr-2"></i> Cancel Request
                        </button>
                    </form>
                    {{/if_eq}}

                    {{#if_eq request.status 'ready'}}
                    <button onclick="openScheduleModal()" class="bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105 shadow-lg">
                        <i class="fas fa-calendar-plus mr-2"></i> Schedule Pickup
                    </button>
                    {{/if_eq}}
                </div>
            </div>
        </div>
    </main>

    <!-- Schedule Appointment Modal -->
    <div id="scheduleModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4">
            <h2 class="text-2xl font-black text-gray-900 mb-6">
                <i class="fas fa-calendar-check mr-2 text-blue-600"></i> Schedule Appointment
            </h2>
            
            <form method="POST" action="/student/appointment/schedule" class="space-y-4">
                <input type="hidden" name="documentRequestId" value="{{request.id}}">
                
                <div>
                    <label for="appointmentDate" class="block text-gray-700 font-bold mb-2">
                        <i class="fas fa-calendar mr-2"></i> Date
                    </label>
                    <input type="date" id="appointmentDate" name="appointmentDate" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-600">
                </div>

                <div>
                    <label for="appointmentTime" class="block text-gray-700 font-bold mb-2">
                        <i class="fas fa-clock mr-2"></i> Time
                    </label>
                    <input type="time" id="appointmentTime" name="appointmentTime" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-600">
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeScheduleModal()" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-bold py-3 rounded-lg transition">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition">
                        <i class="fas fa-check mr-2"></i> Schedule
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openScheduleModal() {
            document.getElementById('scheduleModal').classList.remove('hidden');
        }
        function closeScheduleModal() {
            document.getElementById('scheduleModal').classList.add('hidden');
        }
        // Close modal when clicking outside
        document.getElementById('scheduleModal').addEventListener('click', function(e) {
            if (e.target === this) closeScheduleModal();
        });
    </script>

    {{>footer}}
</body>
</html>
