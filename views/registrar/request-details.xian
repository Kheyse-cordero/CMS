<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Request Details - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes slideInUp {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }
        .animate-fade-in-down { animation: fadeInDown 0.6s ease-out; }
        .animate-slide-in-up { animation: slideInUp 0.8s ease-out; }
        .stat-card { transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .stat-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1); }
    </style>
</head>
<body class="bg-gradient-to-br from-[#E8F5BD] via-indigo-50 to-purple-50 min-h-screen">
    {{>navbar}}
    <main class="md:ml-64 px-4 sm:px-6 lg:px-8 py-12">
        <!-- Page Title -->
        <div class="mb-8 animate-fade-in-down">
            <h1 class="text-3xl font-black text-gray-900 flex items-center mb-2">
                <i class="fas fa-file-alt mr-4 text-[#84B179]"></i> Request Details
            </h1>
            <p class="text-gray-600 text-lg">Process and manage document requests</p>
        </div>

        <!-- Back Button -->
        <div class="mb-6">
            <a href="/registrar/requests" class="inline-flex items-center text-[#84B179] hover:text-purple-800 font-bold transition">
                <i class="fas fa-arrow-left mr-2"></i> Back to Requests
            </a>
        </div>

        <!-- Request Details Card -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden animate-slide-in-up">
            <!-- Header -->
            <div class="bg-gradient-to-r from-purple-600 to-indigo-600 px-8 py-8">
                <div class="flex justify-between items-start">
                    <div>
                        <h2 class="text-white text-3xl font-black flex items-center mb-2">
                            <i class="fas fa-{{#switch request.documentType}}{{#case 'transcript'}}graduation-cap{{/case}}{{#case 'transfer_credentials'}}exchange-alt{{/case}}{{#case 'diploma_second_copy'}}copy{{/case}}{{/switch}} mr-3"></i>
                            {{#switch request.documentType}}{{#case 'transcript'}}Transcript of Records{{/case}}{{#case 'transfer_credentials'}}Certificate of Transfer Credentials and Academic Records{{/case}}{{#case 'diploma_second_copy'}}Second Copy of Diploma{{/case}}{{/switch}}
                        </h2>
                        <p class="text-purple-100">Request ID: {{request.id}}</p>
                    </div>
                    <!-- Status Badge -->
                    <div>
                        {{#switch request.status}}
                            {{#case 'pending'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-yellow-100 text-yellow-800 inline-flex items-center">
                                    <i class="fas fa-hourglass-start mr-2"></i> Pending
                                </span>
                            {{/case}}
                            {{#case 'processing'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-[#C7EABB] text-[#5a7a51] inline-flex items-center">
                                    <i class="fas fa-spinner mr-2"></i> Processing
                                </span>
                            {{/case}}
                            {{#case 'ready'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-green-100 text-green-800 inline-flex items-center">
                                    <i class="fas fa-check-circle mr-2"></i> Ready
                                </span>
                            {{/case}}
                            {{#case 'completed'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-emerald-100 text-emerald-800 inline-flex items-center">
                                    <i class="fas fa-check-double mr-2"></i> Completed
                                </span>
                            {{/case}}
                            {{#case 'rejected'}}
                                <span class="px-6 py-3 rounded-full text-lg font-bold bg-red-100 text-red-800 inline-flex items-center">
                                    <i class="fas fa-times-circle mr-2"></i> Rejected
                                </span>
                            {{/case}}
                        {{/switch}}
                    </div>
                </div>
            </div>

            <!-- Details Content -->
            <div class="px-8 py-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                    <!-- Left Column -->
                    <div class="space-y-6">
                        <div class="stat-card bg-gradient-to-br from-[#E8F5BD] to-indigo-50 p-6 rounded-xl border-l-4 border-[#84B179]">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-user mr-2 text-[#84B179]"></i> STUDENT NAME
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{request.student.name}}</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-green-50 to-emerald-50 p-6 rounded-xl border-l-4 border-green-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-envelope mr-2 text-green-600"></i> STUDENT EMAIL
                            </p>
                            <p class="text-lg font-semibold text-gray-900">{{request.student.email}}</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-yellow-50 to-amber-50 p-6 rounded-xl border-l-4 border-yellow-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-calendar mr-2 text-yellow-600"></i> DATE REQUESTED
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{formatDate request.createdAt}}</p>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="space-y-6">
                        <div class="stat-card bg-gradient-to-br from-amber-50 to-yellow-50 p-6 rounded-xl border-l-4 border-amber-500">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-clock mr-2 text-amber-600"></i> PROCESSING PERIOD
                            </p>
                            <p class="text-xl font-black text-gray-900">6 Working Days</p>
                            <p class="text-sm text-gray-500 mt-1">An appointment is required for document pickup</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-purple-50 to-pink-50 p-6 rounded-xl border-l-4 border-purple-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-copy mr-2 text-[#84B179]"></i> QUANTITY
                            </p>
                            <p class="text-2xl font-black text-gray-900">{{request.quantity}} {{#if_eq request.quantity 1}}Copy{{else}}Copies{{/if_eq}}</p>
                        </div>

                        <div class="stat-card bg-gradient-to-br from-indigo-50 to-[#E8F5BD] p-6 rounded-xl border-l-4 border-indigo-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-info-circle mr-2 text-[#84B179]"></i> PURPOSE
                            </p>
                            <p class="text-gray-900 font-semibold">{{request.purpose}}</p>
                        </div>

                        {{#if request.notes}}
                        <div class="stat-card bg-gradient-to-br from-orange-50 to-red-50 p-6 rounded-xl border-l-4 border-orange-600">
                            <p class="text-gray-600 text-sm font-bold mb-2">
                                <i class="fas fa-sticky-note mr-2 text-orange-600"></i> NOTES
                            </p>
                            <p class="text-gray-900">{{request.notes}}</p>
                        </div>
                        {{/if}}
                    </div>
                </div>

                <!-- Status Update Section -->
                <div class="mt-12 pt-8 border-t-2 border-gray-200">
                    <h3 class="text-2xl font-black text-gray-900 mb-6 flex items-center">
                        <i class="fas fa-tasks mr-3 text-[#84B179]"></i> Update Request Status
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {{#if_eq request.status 'pending'}}
                        <button onclick="openStatusModal('processing')" class="bg-gradient-to-br from-[#84B179] to-[#84B179] hover:from-[#84B179] hover:to-[#6b9460] text-white font-bold py-4 px-6 rounded-lg transition transform hover:scale-105 shadow-lg flex items-center justify-center">
                            <i class="fas fa-spinner mr-2"></i> Start Processing
                        </button>
                        {{/if_eq}}

                        {{#if_eq request.status 'processing'}}
                        <button onclick="openStatusModal('ready')" class="bg-gradient-to-br from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white font-bold py-4 px-6 rounded-lg transition transform hover:scale-105 shadow-lg flex items-center justify-center">
                            <i class="fas fa-check-circle mr-2"></i> Mark as Ready
                        </button>
                        {{/if_eq}}

                        {{#if_eq request.status 'ready'}}
                        <button onclick="openStatusModal('completed')" class="bg-gradient-to-br from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white font-bold py-4 px-6 rounded-lg transition transform hover:scale-105 shadow-lg flex items-center justify-center">
                            <i class="fas fa-check-double mr-2"></i> Mark as Completed
                        </button>
                        {{/if_eq}}

                        {{#unless_eq request.status 'rejected'}}
                        <button onclick="openRejectModal()" class="bg-gradient-to-br from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 text-white font-bold py-4 px-6 rounded-lg transition transform hover:scale-105 shadow-lg flex items-center justify-center">
                            <i class="fas fa-times-circle mr-2"></i> Reject Request
                        </button>
                        {{/unless_eq}}
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Status Update Modal -->
    <div id="statusModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4">
            <h2 class="text-2xl font-black text-gray-900 mb-6">
                <i class="fas fa-tasks mr-2 text-[#84B179]"></i> Update Status
            </h2>
            
            <form method="POST" action="/registrar/requests/{{request.id}}/status" class="space-y-4">
                <input type="hidden" id="statusInput" name="status" value="">
                
                <div>
                    <label for="notes" class="block text-gray-700 font-bold mb-2">
                        <i class="fas fa-sticky-note mr-2"></i> Additional Notes (Optional)
                    </label>
                    <textarea id="notes" name="notes" rows="4" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" placeholder="Add any notes about this status update..."></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeStatusModal()" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-bold py-3 rounded-lg transition">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-lg transition">
                        <i class="fas fa-check mr-2"></i> Update
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reject Modal -->
    <div id="rejectModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4">
            <h2 class="text-2xl font-black text-gray-900 mb-6">
                <i class="fas fa-times-circle mr-2 text-red-600"></i> Reject Request
            </h2>
            
            <form method="POST" action="/registrar/requests/{{request.id}}/status" class="space-y-4">
                <input type="hidden" name="status" value="rejected">
                
                <div>
                    <label for="rejectionReason" class="block text-gray-700 font-bold mb-2">
                        <i class="fas fa-exclamation-triangle mr-2"></i> Rejection Reason
                    </label>
                    <textarea id="rejectionReason" name="rejectionReason" rows="4" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600" placeholder="Please provide a reason for rejecting this request..."></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeRejectModal()" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-bold py-3 rounded-lg transition">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-lg transition">
                        <i class="fas fa-times mr-2"></i> Reject
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openStatusModal(status) {
            document.getElementById('statusInput').value = status;
            document.getElementById('statusModal').classList.remove('hidden');
        }
        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
        }

        function openRejectModal() {
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
        }

        // Close modals when clicking outside
        document.getElementById('statusModal').addEventListener('click', function(e) {
            if (e.target === this) closeStatusModal();
        });
        document.getElementById('rejectModal').addEventListener('click', function(e) {
            if (e.target === this) closeRejectModal();
        });
    </script>

    {{>footer}}
</body>
</html>
