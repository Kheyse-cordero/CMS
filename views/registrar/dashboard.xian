<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Dashboard - MinSU DocuReg</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; opacity: 0; }
        .animate-fade-in-down { animation: fadeInDown 0.6s ease-out; }
        .stat-card { transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .stat-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1); }
        .action-btn { transition: all 0.3s ease; }
        .action-btn:hover { transform: scale(1.05); box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15); }
        .table-row-hover { transition: all 0.2s ease; }
        .table-row-hover:hover { background-color: #f3f4f6; transform: translateX(4px); }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 via-purple-50 to-gray-100 min-h-screen">
    {{>navbar}}

    <main class="max-w-7xl mx-auto px-6 py-12 pt-24">
        <!-- Page Title -->
        <div class="animate-fade-in-down mb-10">
            <h1 class="text-5xl font-black text-gray-800 mb-2">Registrar Dashboard</h1>
            <p class="text-gray-600 text-lg">Process and manage student document requests efficiently</p>
        </div>

        <!-- Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-12">
            <div class="stat-card bg-gradient-to-br from-yellow-50 to-amber-100 rounded-xl shadow-lg p-8 border-l-4 border-yellow-600 animate-fade-in-up" style="animation-delay: 0.1s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-yellow-700 text-sm font-bold mb-3 uppercase tracking-wide">Pending</p>
                        <p class="text-4xl font-black text-yellow-600">{{stats.pendingRequests}}</p>
                    </div>
                    <div class="bg-yellow-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-hourglass-half text-4xl text-yellow-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-blue-50 to-cyan-100 rounded-xl shadow-lg p-8 border-l-4 border-blue-600 animate-fade-in-up" style="animation-delay: 0.15s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-blue-700 text-sm font-bold mb-3 uppercase tracking-wide">Processing</p>
                        <p class="text-4xl font-black text-blue-600">{{stats.processingRequests}}</p>
                    </div>
                    <div class="bg-blue-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-cog text-4xl text-blue-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-green-50 to-emerald-100 rounded-xl shadow-lg p-8 border-l-4 border-green-600 animate-fade-in-up" style="animation-delay: 0.2s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-green-700 text-sm font-bold mb-3 uppercase tracking-wide">Ready</p>
                        <p class="text-4xl font-black text-green-600">{{stats.readyRequests}}</p>
                    </div>
                    <div class="bg-green-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-check text-4xl text-green-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl shadow-lg p-8 border-l-4 border-purple-600 animate-fade-in-up" style="animation-delay: 0.25s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-purple-700 text-sm font-bold mb-3 uppercase tracking-wide">Total</p>
                        <p class="text-4xl font-black text-purple-600">{{stats.totalRequests}}</p>
                    </div>
                    <div class="bg-purple-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-file-alt text-4xl text-purple-600 opacity-70"></i>
                    </div>
                </div>
            </div>
            <div class="stat-card bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl shadow-lg p-8 border-l-4 border-indigo-600 animate-fade-in-up" style="animation-delay: 0.3s">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-indigo-700 text-sm font-bold mb-3 uppercase tracking-wide">Today</p>
                        <p class="text-4xl font-black text-indigo-600">{{stats.todayAppointments}}</p>
                    </div>
                    <div class="bg-indigo-600 bg-opacity-20 rounded-full p-4">
                        <i class="fas fa-calendar text-4xl text-indigo-600 opacity-70"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="action-btn bg-gradient-to-br from-yellow-500 to-orange-500 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.35s">
                <div class="mb-6"><i class="fas fa-tasks text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Pending Requests</h3>
                <p class="mb-8 text-yellow-100 text-lg">Review new document requests</p>
                <a href="/registrar/requests" class="inline-block bg-white text-yellow-600 px-8 py-3 rounded-xl font-bold hover:bg-yellow-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
            <div class="action-btn bg-gradient-to-br from-blue-500 to-cyan-500 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.4s">
                <div class="mb-6"><i class="fas fa-calendar-check text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Appointments</h3>
                <p class="mb-8 text-blue-100 text-lg">Manage appointment schedules</p>
                <a href="/registrar/appointments" class="inline-block bg-white text-blue-600 px-8 py-3 rounded-xl font-bold hover:bg-blue-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
            <div class="action-btn bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl shadow-xl p-8 text-white transform hover:shadow-2xl animate-fade-in-up" style="animation-delay: 0.45s">
                <div class="mb-6"><i class="fas fa-chart-bar text-6xl opacity-90"></i></div>
                <h3 class="text-2xl font-black mb-3">Reports</h3>
                <p class="mb-8 text-purple-100 text-lg">View analytics and reports</p>
                <a href="/registrar/report" class="inline-block bg-white text-purple-600 px-8 py-3 rounded-xl font-bold hover:bg-purple-50 transition transform hover:scale-105 shadow-lg"><i class="fas fa-arrow-right mr-2"></i> View</a>
            </div>
        </div>

        <!-- Recent Requests -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden animate-fade-in-up" style="animation-delay: 0.5s">
            <div class="bg-gradient-to-r from-gray-800 to-gray-900 px-8 py-6">
                <h2 class="text-white text-2xl font-black flex items-center"><i class="fas fa-history mr-3"></i> Recent Requests</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-100 border-b-2 border-gray-300">
                        <tr>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Student</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Document</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Status</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Date</th>
                            <th class="px-8 py-4 text-left text-gray-800 font-bold">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each recentRequests}}
                            <tr class="table-row-hover border-b-2 border-gray-200">
                                <td class="px-8 py-5 text-gray-800 font-medium"><i class="fas fa-user mr-2 text-blue-600"></i>{{this.student.name}}</td>
                                <td class="px-8 py-5 text-gray-600">{{this.documentType}}</td>
                                <td class="px-8 py-5">
                                    {{#switch this.status}}
                                        {{#case 'pending'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 inline-flex items-center"><i class="fas fa-hourglass-start mr-2"></i>Pending</span>{{/case}}
                                        {{#case 'processing'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-blue-100 text-blue-800 inline-flex items-center"><i class="fas fa-spinner mr-2"></i>Processing</span>{{/case}}
                                        {{#case 'ready'}}<span class="px-4 py-2 rounded-full text-sm font-bold bg-green-100 text-green-800 inline-flex items-center"><i class="fas fa-check-circle mr-2"></i>Ready</span>{{/case}}
                                    {{/switch}}
                                </td>
                                <td class="px-8 py-5 text-gray-600 font-medium">{{formatDate this.createdAt}}</td>
                                <td class="px-8 py-5"><a href="/registrar/requests/{{this.id}}" class="text-blue-600 hover:text-blue-800 font-bold inline-flex items-center transition hover:translate-x-1"><i class="fas fa-arrow-right mr-2"></i>Process</a></td>
                            </tr>
                        {{else}}
                            <tr>
                                <td colspan="5" class="px-8 py-8 text-center text-gray-500"><i class="fas fa-inbox text-3xl mb-2 block opacity-50"></i>No recent requests</td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    {{>footer}}
</body>
</html>
